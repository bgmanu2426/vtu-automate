# API Configuration
VTU_API_BASE_URL=https://online.vtu.ac.in/api/v1

# Parallel Processing
VTU_BATCH_SIZE=10
VTU_MAX_ATTEMPTS=100

# FastAPI runtime defaults (web queue mode)
MAX_CONCURRENT=2
DEFAULT_BATCH_SIZE=10
DEFAULT_MAX_ATTEMPTS=50
RETRY_DELAY_MS=2000
REQUEST_DELAY_MS=500

# Allowed CORS origin for deployed frontend (use * during local dev)
CORS_ORIGIN=*

# GitHub repo URL shown in UI and /api/stats
GITHUB_URL=https://github.com/bgmanu2426/vtu-automate

# Admin endpoints password (optional)
ADMIN_PASSWORD=change-me

# Upstash KV (optional stats backend)
# Get these from https://console.upstash.com -> your Redis database -> REST API
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-rest-api-token
